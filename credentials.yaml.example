# Copy to credentials.yaml (gitignored) and generate tokens with:
#   python -c "import secrets; print(secrets.token_urlsafe(8))"
#
# Tier hierarchy: public ⊂ recruiter ⊂ personal
tokens:
  "":
    tier: public
    label: "anonymous / QR code"
  "rec-REPLACE_ME":
    tier: recruiter
    label: "shared recruiter link"
  "pers-REPLACE_ME":
    tier: personal
    label: "inner circle"
